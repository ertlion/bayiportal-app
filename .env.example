# Database
DATABASE_URL=postgresql://user:pass@host/bayiportal_app

# Shopify App
SHOPIFY_API_KEY=your-api-key
SHOPIFY_API_SECRET=your-api-secret
SHOPIFY_SCOPES=read_products,read_inventory,write_inventory,read_orders
APP_URL=https://app.bayiportal.com

# Cron
CRON_SECRET=your-cron-secret

# Email
RESEND_API_KEY=re_xxx

# Encryption key for marketplace credentials (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
